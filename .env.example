# EyeX Technologies — Environment Variables Template
# Copy this file to `.env` and fill in your real values.
# NEVER commit `.env` to git.

# Supabase (frontend + backend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (backend only — keep secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AI providers
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Stitch SDK (brand screen generation)
STITCH_API_KEY=your-stitch-api-key-here

# Python backend (used by frontend to reach FastAPI)
VITE_PYTHON_BACKEND_URL=/api/v1

# Application secrets (generate strong random values)
APP_SECRET_KEY=change-me-to-a-random-64-char-string
