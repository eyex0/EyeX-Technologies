# Environment
ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# Application
APP_NAME=EyeX Technologies
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=eyex
POSTGRES_PASSWORD=eyex_secret
POSTGRES_DB=eyex

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.0

# LangChain
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-langchain-api-key
LANGCHAIN_PROJECT=eyex-technologies

# Security
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false
