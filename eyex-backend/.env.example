# EyeX Technologies — Backend Environment Configuration

# Application
APP_NAME="EyeX Technologies"
APP_VERSION="0.1.0"
APP_DEBUG=false
APP_SECRET_KEY=change-this-to-a-random-64-char-string

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
CORS_ORIGINS=["http://localhost:3000","https://eyex-technologies.eyextech.workers.dev"]

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://eyex:eyex_password@localhost:5432/eyex
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# OpenAI / LangChain
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=4096

# LangGraph
LANGGRAPH_STORE_TYPE=memory
LANGGRAPH_CHECKPOINT_INTERVAL=5

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
BCRYPT_ROUNDS=12

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# OpenTelemetry (optional)
OTLP_ENDPOINT=
