# EyeX Technologies — Production Environment Template
# Copy to .env.production and fill with real secrets before deploying.

APP_NAME=EyeX Technologies
APP_VERSION=1.0.0-rc1
APP_ENVIRONMENT=production
APP_SECRET_KEY=change-me-to-a-random-64-char-string

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
CORS_ORIGINS=https://eyex-technologies.eyextech.workers.dev
TRUSTED_HOSTS=eyex-api,localhost
REQUIRE_HTTPS=true
ENABLE_SECURITY_HEADERS=true

# Database
DATABASE_URL=postgresql+asyncpg://eyex:strong_password@postgres:5432/eyex
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=2048

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
OTLP_ENDPOINT=

# PostgreSQL container
POSTGRES_USER=eyex
POSTGRES_PASSWORD=strong_password
POSTGRES_DB=eyex

# Backup
BACKUP_RETENTION_DAYS=14
